# LLMOps Environment Configuration

# ===================
# Model Configuration
# ===================
MODEL_NAME=meta-llama/Llama-2-7b-chat-hf
MODEL_REVISION=main
TGI_MODEL_ID=meta-llama/Llama-2-7b-chat-hf

# HuggingFace Token (required for gated models)
HUGGINGFACE_TOKEN=your_huggingface_token_here

# ===================
# GPU Configuration
# ===================
GPU_COUNT=1
GPU_DEVICES=0
TENSOR_PARALLEL_SIZE=1

# ===================
# Model Parameters
# ===================
MAX_MODEL_LEN=4096
MAX_INPUT_LENGTH=1024
MAX_TOTAL_TOKENS=2048
NUM_SHARD=1

# Quantization (options: awq, gptq, bitsandbytes, none)
QUANTIZATION=none

# ===================
# MLflow Configuration
# ===================
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_BACKEND_STORE_URI=sqlite:///mlflow.db
MLFLOW_ARTIFACT_ROOT=/mlflow/artifacts

# ===================
# Qdrant Configuration
# ===================
QDRANT_API_KEY=your_qdrant_api_key_here
QDRANT_COLLECTION=embeddings
QDRANT_VECTOR_SIZE=768

# ===================
# Grafana Configuration
# ===================
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin_change_me

# ===================
# API Gateway
# ===================
NGINX_RATE_LIMIT=10r/s
ENABLE_SSL=false

# ===================
# Logging
# ===================
LOG_LEVEL=INFO
LOG_FORMAT=json
